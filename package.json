{
  "name": "butler-dispatch-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "test": "tsx --test tests/lib/*.test.ts",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "miniprogram:build": "tsc -p miniprogram/tsconfig.json",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "backup": "bash scripts/backup-to-github.sh",
    "cron:overdue-assignments": "tsx scripts/resolve-overdue-assignments.ts",
    "data:clean-overdue-abnormal-descriptions": "tsx scripts/clean-overdue-abnormal-descriptions.ts",
    "data:clean-overdue-operation-log-remarks": "tsx scripts/clean-overdue-operation-log-remarks.ts"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.5",
    "@ant-design/nextjs-registry": "1.3.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@prisma/client": "6.19.3",
    "antd": "6.4.5",
    "bcryptjs": "3.0.3",
    "dayjs": "1.11.13",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "exceljs": "^4.4.0",
    "jose": "6.2.3",
    "next": "16.2.9",
    "pinyin-pro": "^3.28.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "prisma": "6.19.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
