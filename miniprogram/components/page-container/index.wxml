<view class="page-container">
  <view
    class="{{hero ? 'hero-head' : 'plain-head'}}"
    style="padding-top: {{headTop}}rpx;"
  >
    <view
      wx:if="{{canGoBack}}"
      class="back-button"
      style="top: {{backTop}}rpx;"
      bindtap="goBack"
    >
      <view class="back-icon"></view>
    </view>
    <view
      class="title-wrap {{canGoBack ? 'has-back' : ''}}"
      style="padding-right: {{titleRightInset}}rpx;"
    >
      <view class="title">{{title}}</view>
      <view wx:if="{{subtitle}}" class="subtitle">{{subtitle}}</view>
    </view>
    <view class="hero-slot-wrap">
      <slot name="hero"></slot>
    </view>
  </view>
  <slot></slot>
</view>
