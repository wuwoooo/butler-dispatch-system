/* 表单单元格 */
.form-cell {
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  transition: all var(--duration-normal) var(--ease-smooth);
}

.form-cell:last-child {
  border-bottom: 0;
}

.form-label {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  transition: color var(--duration-fast);
}

.required {
  color: var(--color-danger);
  margin-right: 6rpx;
}

.form-control {
  min-height: 76rpx;
}

.form-desc {
  margin-top: 12rpx;
  color: var(--color-text-tertiary);
  font-size: 22rpx;
}

/* 错误与禁用状态 */
.is-error .form-label {
  color: var(--color-danger);
}

.error-message {
  margin-top: 12rpx;
  color: var(--color-danger);
  font-size: 22rpx;
  font-weight: 600;
}

.is-disabled {
  opacity: 0.55;
  pointer-events: none;
}
