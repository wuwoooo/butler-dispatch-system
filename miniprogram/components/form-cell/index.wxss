/* 表单单元格 */
.form-cell {
  padding: 26rpx 0;
  border-bottom: 1rpx solid #EDF1F7;
}

.form-cell:last-child {
  border-bottom: 0;
}

.form-label {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2332;
}

.required {
  color: #EF4444;
  margin-right: 4rpx;
}

.form-control {
  min-height: 76rpx;
}

.form-desc {
  margin-top: 10rpx;
  color: #94A3B8;
  font-size: 22rpx;
}
