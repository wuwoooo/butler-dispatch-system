/* 空状态 */
.empty-state {
  margin: 60rpx 32rpx;
  padding: 60rpx 36rpx;
  text-align: center;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(26, 35, 50, 0.05);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: #EAF6FD;
  color: #2AACE2;
  font-size: 60rpx;
  line-height: 120rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A2332;
}

.empty-description {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: #5A6B82;
}

.empty-button {
  display: inline-flex;
  margin-top: 32rpx;
  padding: 0 36rpx;
  height: 68rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: #EAF6FD;
  color: #2AACE2;
  font-size: 26rpx;
  font-weight: 700;
  transition: all 0.2s ease;
}

.empty-button:active {
  background: #D5EEFC;
  transform: scale(0.97);
}
