<view wx:if="{{visible}}" class="picker-mask">
  <view class="picker-panel" catchtap="noop">
    <view class="picker-title">{{title}}</view>
    <view class="picker-tip">默认使用当前时间，可按实际情况调整。</view>
    <view class="picker-row">
      <view class="picker-label">日期</view>
      <picker mode="date" value="{{date}}" bindchange="setDate">
        <view class="picker-value">{{date}}</view>
      </picker>
    </view>
    <view class="picker-row">
      <view class="picker-label">时间</view>
      <picker mode="time" value="{{time}}" bindchange="setTime">
        <view class="picker-value">{{time}}</view>
      </picker>
    </view>
    <view class="picker-actions">
      <button class="picker-button picker-cancel" catchtap="cancel">取消</button>
      <button class="picker-button picker-confirm" catchtap="confirm">确认</button>
    </view>
  </view>
</view>
