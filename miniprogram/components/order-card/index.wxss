/* 订单卡片 */
.order-card {
  margin: 20rpx 32rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(26, 35, 50, 0.06),
              0 12rpx 32rpx rgba(26, 35, 50, 0.04);
  transition: transform 0.2s ease;
}

.order-card:active {
  transform: scale(0.985);
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.hotel-name {
  max-width: 430rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #1A2332;
}

.order-no {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94A3B8;
}

.guest-line {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #2AACE2;
}

.info-grid {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  background: #F8FAFD;
  border-radius: 18rpx;
}

.info-item {
  font-size: 25rpx;
  color: #5A6B82;
  line-height: 1.5;
}

.card-footer {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #EDF1F7;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.action-btn {
  height: 72rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.action-btn.reject {
  color: #EF4444;
  background: #FEF2F2;
}

.action-btn.confirm {
  color: #ffffff;
  background: linear-gradient(135deg, #2AACE2 0%, #1B8FD4 100%);
}

.action-btn:active {
  opacity: 0.82;
}

.footer-muted {
  color: #94A3B8;
  font-size: 24rpx;
}

.tap-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #D8E1EC;
}
