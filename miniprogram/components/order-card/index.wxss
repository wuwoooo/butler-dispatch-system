/* 订单卡片 */
.order-card {
  margin: 24rpx var(--spacing-2xl);
  padding: 32rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  box-shadow: 0 12rpx 36rpx rgba(26, 35, 50, 0.05);
  transition: all var(--duration-fast) var(--ease-smooth);
}

.order-card:active {
  transform: translateY(2rpx) scale(0.985);
  box-shadow: 0 6rpx 16rpx rgba(26, 35, 50, 0.03);
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--spacing-md);
}

.title-section {
  flex: 1;
  min-width: 0;
}

.hotel-name {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  word-break: break-all;
}

.order-no {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.guest-line {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary-deep);
}

.info-grid {
  margin-top: 24rpx;
  padding: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  background: rgba(42, 172, 226, 0.03);
  border: 1rpx solid rgba(42, 172, 226, 0.05);
  border-radius: var(--radius-md);
}

.info-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

/* 伪元素画图标 */
.info-item::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.info-pickup::before {
  background: var(--color-primary);
  box-shadow: 0 0 6rpx rgba(42, 172, 226, 0.4);
}

.info-arrival::before {
  background: var(--color-warning);
  box-shadow: 0 0 6rpx rgba(245, 158, 11, 0.4);
}

.info-checkin::before {
  background: var(--color-success);
  box-shadow: 0 0 6rpx rgba(16, 185, 129, 0.4);
}

.info-room::before {
  background: var(--color-purple);
  box-shadow: 0 0 6rpx rgba(124, 58, 237, 0.4);
}

.card-footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-xl);
}

.action-btn {
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box;
  height: 76rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
}

.action-btn::after {
  border: none !important;
}

.action-btn.reject {
  color: var(--color-danger);
  background: var(--color-danger-light);
  border: 1rpx solid rgba(239, 68, 68, 0.15);
}

.action-btn.confirm {
  color: #ffffff;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 100%);
  box-shadow: var(--shadow-primary);
}

.action-btn:active {
  opacity: 0.85;
}

.footer-muted {
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  font-weight: 500;
}

.chevron {
  width: 12rpx;
  height: 12rpx;
  border-right: 3rpx solid var(--color-decor);
  border-top: 3rpx solid var(--color-decor);
  transform: rotate(45deg);
}
