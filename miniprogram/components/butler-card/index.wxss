/* 管家卡片 */
.butler-card {
  margin: 20rpx 32rpx;
  padding: 26rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(26, 35, 50, 0.06),
              0 12rpx 32rpx rgba(26, 35, 50, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.butler-card:active {
  transform: scale(0.985);
}

.selected {
  border-color: #2AACE2;
  background: #F0F8FF;
}

.disabled {
  opacity: 0.58;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2AACE2 0%, #1B8FD4 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(42, 172, 226, 0.25);
}

.content {
  flex: 1;
  min-width: 0;
}

.top-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A2332;
}

.meta {
  margin-top: 8rpx;
  color: #5A6B82;
  font-size: 24rpx;
}

.reason {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  color: #5A6B82;
  background: #F0F4FA;
  font-size: 22rpx;
  line-height: 1.5;
}

.check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #2AACE2;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(42, 172, 226, 0.30);
}
