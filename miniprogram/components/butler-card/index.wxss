/* 管家卡片 */
.butler-card {
  margin: 20rpx var(--spacing-2xl);
  padding: 26rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-md);
  border: 3rpx solid transparent;
  transition: all var(--duration-normal) var(--ease-smooth);
}

.butler-card:active {
  transform: scale(0.985);
}

.selected {
  border-color: var(--color-primary);
  background: var(--color-primary-lighter);
}

.disabled {
  opacity: 0.58;
}

/* 头像环状态指示器 */
.avatar-wrap {
  position: relative;
  width: 86rpx;
  height: 86rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-ring {
  position: absolute;
  inset: -2rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-decor);
}

.avatar-ring-available {
  border-color: var(--color-success);
}

.avatar-ring-on_leave {
  border-color: var(--color-warning);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  box-shadow: var(--shadow-sm);
  z-index: 1;
}

.content {
  flex: 1;
  min-width: 0;
}

.top-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--spacing-sm);
}

.name {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--color-text-primary);
}

.meta {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.meta-with-phone {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.reason {
  margin-top: 12rpx;
  padding: 12rpx var(--spacing-md);
  border-radius: var(--radius-sm);
  color: var(--color-warning-deep);
  background: var(--color-warning-light);
  font-size: 22rpx;
  line-height: 1.5;
  display: flex;
  align-items: center;
  font-weight: 500;
}

.reason-icon {
  margin-right: 6rpx;
  font-size: 22rpx;
}

.check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-fast);
}

.check-active {
  animation: bounceIn 0.35s var(--ease-spring) both;
}
