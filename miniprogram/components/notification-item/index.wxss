/* 通知卡片 */
.notification {
  position: relative;
  margin: 20rpx var(--spacing-2xl);
  padding: 28rpx 30rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-md);
  border-left: 6rpx solid var(--color-primary);
  transition: transform var(--duration-fast) var(--ease-smooth);
}

.notification:active {
  transform: scale(0.985);
}

.read {
  opacity: 0.65;
  border-left-color: transparent;
}

.dot {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-primary);
  box-shadow: 0 0 8rpx rgba(42, 172, 226, 0.45);
  animation: pulse 2.5s ease-in-out infinite;
}

.notification-body {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
}

/* ── 类型图标 ── */
.noti-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.noti-icon-inner {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

/* 订单类 */
.noti-icon-order {
  background: var(--color-primary-light);
  color: var(--color-primary);
}
.noti-icon-order .noti-icon-inner::before {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 2rpx;
  width: 20rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-radius: 3rpx;
}
.noti-icon-order .noti-icon-inner::after {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 12rpx;
  width: 10rpx;
  height: 6rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(-45deg);
}

/* 请假类 */
.noti-icon-leave {
  background: var(--color-success-light);
  color: var(--color-success-deep);
}
.noti-icon-leave .noti-icon-inner::before {
  content: '';
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  right: 4rpx;
  bottom: 2rpx;
  border: 3rpx solid currentColor;
  border-radius: 3rpx;
}
.noti-icon-leave .noti-icon-inner::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 0;
  width: 2rpx;
  height: 6rpx;
  background: currentColor;
  box-shadow: 14rpx 0 0 currentColor;
}

/* 评价类 */
.noti-icon-review {
  background: var(--color-warning-light);
  color: var(--color-warning-deep);
}
.noti-icon-review .noti-icon-inner::before {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background: currentColor;
  transform: rotate(45deg);
}

/* 系统/其他 */
.noti-icon-system {
  background: var(--color-bg-info);
  color: var(--color-text-secondary);
}
.noti-icon-system .noti-icon-inner::before {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 4rpx;
  width: 14rpx;
  height: 18rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 7rpx 7rpx 0 0;
}
.noti-icon-system .noti-icon-inner::after {
  content: '';
  position: absolute;
  left: 6rpx;
  bottom: 6rpx;
  width: 20rpx;
  height: 3rpx;
  background: currentColor;
  box-shadow: 7rpx 4rpx 0 currentColor;
}

.content {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.text {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 25rpx;
  line-height: 1.5;
}

.time {
  margin-top: 14rpx;
  color: var(--color-text-tertiary);
  font-size: 22rpx;
  font-weight: 500;
}
