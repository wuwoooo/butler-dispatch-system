/* 加载状态 */
.loading-state {
  display: flex;
  gap: var(--spacing-sm);
  align-items: center;
  justify-content: center;
  padding: 64rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 5rpx solid var(--color-primary-light);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: rotate 0.8s linear infinite;
}

/* 骨架屏样式 */
.skeleton-container {
  padding: var(--spacing-sm) 0;
}

.skeleton-card {
  margin: var(--spacing-lg) var(--spacing-2xl);
  padding: 30rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  animation: fadeInUp var(--duration-slow) var(--ease-smooth) both;
}

.skeleton-card:nth-child(2) {
  animation-delay: 0.1s;
}

.skeleton-card:nth-child(3) {
  animation-delay: 0.2s;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #EDF1F7 25%, #E5EAF2 37%, #EDF1F7 63%);
  background-size: 400% 100%;
  animation: shimmer 1.5s ease infinite;
  border-radius: var(--radius-sm);
  margin-bottom: var(--spacing-md);
}

.skeleton-title-line {
  width: 40%;
  height: 32rpx;
}

.skeleton-short-line {
  width: 25%;
  height: 22rpx;
}

.skeleton-grid-block {
  height: 120rpx;
  background: linear-gradient(90deg, #F5F8FC 25%, #EDF1F7 37%, #F5F8FC 63%);
  background-size: 400% 100%;
  animation: shimmer 1.5s ease infinite;
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
}

.skeleton-footer-line {
  width: 100%;
  height: 20rpx;
  margin-bottom: 0;
}
