@import "../../../styles/shared.wxss";

/* 派单详情 */
.status-line {
  margin: 12rpx var(--spacing-2xl) var(--spacing-lg);
}

.row-emoji-icon {
  font-size: 32rpx;
  line-height: 1;
  filter: grayscale(0.1);
  margin-right: var(--spacing-xs);
}

.row-value {
  text-align: right;
  font-weight: 600;
}

.assigned-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.assigned-row:last-child {
  border-bottom: 0;
}

.assigned-main {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  flex: 1;
  min-width: 0;
}

.assigned-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary-lighter) 100%);
  color: var(--color-primary-deep);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  flex-shrink: 0;
  border: 1rpx solid rgba(42, 172, 226, 0.15);
}

.assigned-info {
  flex: 1;
  min-width: 0;
}

.assigned-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.assigned-tag-wrap {
  display: flex;
  margin-top: 6rpx;
}

.cancel-dispatch-btn {
  width: auto !important;
  margin: 0 !important;
  padding: 0 var(--spacing-md) !important;
  box-sizing: border-box;
  height: 60rpx;
  line-height: 58rpx;
  border: 1rpx solid var(--color-danger);
  border-radius: var(--radius-sm);
  background: var(--color-danger-light);
  color: var(--color-danger);
  font-size: 22rpx;
  font-weight: 700;
  transition: all var(--duration-fast);
}

.cancel-dispatch-btn::after {
  border: none !important;
}

.cancel-dispatch-btn:active {
  background: #FEE2E2;
  transform: scale(0.96);
}

.block-title {
  margin: 38rpx var(--spacing-2xl) 12rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.block-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
}

.block-title-text {
  flex: 1;
}

.multi-select-toggle {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 600;
}

.multi-select-toggle switch {
  transform: scale(0.78);
  transform-origin: right center;
}

.candidates-list {
  padding-bottom: calc(92rpx + var(--spacing-2xl));
}

.candidates-list .butler-card {
  margin-bottom: var(--spacing-lg) !important;
}

.amount-panel {
  margin: 0 var(--spacing-2xl) calc(120rpx + var(--spacing-2xl));
  padding: var(--spacing-lg);
  border-radius: var(--radius-lg);
  background: #fff;
  box-shadow: var(--shadow-sm);
}

.amount-label {
  margin-bottom: var(--spacing-sm);
  color: var(--color-text-primary);
  font-weight: 700;
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0 var(--spacing-md);
  height: 76rpx;
}

.amount-prefix {
  color: var(--color-primary);
  font-weight: 800;
  margin-right: var(--spacing-xs);
}

.amount-input {
  flex: 1;
  height: 76rpx;
}

.amount-hint {
  margin-top: var(--spacing-xs);
  color: var(--color-text-secondary);
  font-size: 22rpx;
}
