<page-container title="{{order.hotel.name || '派单详情'}}" subtitle="订单号：{{order.orderNo}}">
  <view class="status-line anim-fade-in"><status-tag type="order" value="{{order.status}}" /></view>
  
  <section-card
    wx:for="{{sections}}"
    wx:key="title"
    class="anim-fade-in anim-stagger-{{index + 1}}"
    title="{{item.title}}"
  >
    <view wx:for="{{item.rows}}" wx:key="0" wx:for-item="row" class="detail-row">
      <view class="row-label">
        <view class="row-dot-decor"></view>
        <text>{{row[0]}}</text>
      </view>
      <view class="row-value">{{row[1] || '-'}}</view>
    </view>
  </section-card>

  <view class="anim-fade-in anim-stagger-3">
    <section-card title="已分配管家">
      <view wx:for="{{assigned}}" wx:key="id" class="assigned-row">
        <view class="assigned-main">
          <view class="assigned-avatar">{{item.avatar}}</view>
          <view class="assigned-info">
            <view class="assigned-name">{{item.butler.name}}</view>
            <view class="assigned-tag-wrap">
              <status-tag type="assignment" value="{{item.status}}" size="sm" />
            </view>
          </view>
        </view>
        <button
          wx:if="{{item.status === 'pending_confirm'}}"
          class="cancel-dispatch-btn"
          data-id="{{item.id}}"
          bindtap="cancelAssignment"
        >
          取消派单
        </button>
      </view>
      <empty-state wx:if="{{assigned.length === 0}}" scene="butlers" title="尚未分配管家" description="当前订单暂无派单管家，请选择可用人手进行派单" />
    </section-card>
  </view>

  <view wx:if="{{canDispatch}}" class="block-title anim-fade-in anim-stagger-4">
    <text class="block-title-text">选择可用管家</text>
    <view class="multi-select-toggle">
      <text>多选</text>
      <switch checked="{{multiSelectEnabled}}" bindchange="onMultiSelectChange" color="#2AACE2" />
    </view>
  </view>
  
  <view wx:if="{{canDispatch}}" class="candidates-list anim-fade-in anim-stagger-5">
    <butler-card wx:for="{{candidates}}" wx:key="id" item="{{item}}" selectable="{{true}}" selected="{{item.selected}}" bind:select="selectButler" />
  </view>

  <view wx:if="{{canDispatch}}" class="amount-panel anim-fade-in anim-stagger-5">
    <view class="amount-label">收费金额</view>
    <view class="amount-input-wrap">
      <text class="amount-prefix">¥</text>
      <input class="amount-input" type="digit" value="{{settlementAmount}}" placeholder="允许填写 0.00" bindinput="onAmountInput" />
    </view>
    <view class="amount-hint">每辆车按默认价计费并自动合计；重新选择管家时会覆盖人工改价。</view>
  </view>

  <view wx:if="{{canDispatch}}" class="fixed-action anim-fade-in anim-stagger-5">
    <primary-button text="确认并提交派单" bind:tap="submit" />
  </view>
</page-container>
