@import "../../../styles/shared.wxss";

/* 调配首页 */
.hero-split-layout {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--spacing-lg);
  width: 100%;
  box-sizing: border-box;
  padding: 10rpx 0 20rpx;
}

.hero-main-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hero-greet-line {
  color: #ffffff;
  display: flex;
  align-items: baseline;
}

.hero-greet-title {
  font-size: 38rpx;
  font-weight: 800;
  opacity: 0.95;
}

.hero-username {
  font-size: 44rpx;
  font-weight: 900;
  text-shadow: 0 2rpx 4rpx rgba(21, 46, 82, 0.25);
}

.hero-date-line {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  font-weight: 600;
  line-height: 1.5;
}

.hero-controls-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-top: 24rpx;
}

.status-pill-glass {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 26rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.20);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.status-indicator-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--color-success);
  border-radius: 50%;
  box-shadow: 0 0 10rpx var(--color-success);
  animation: pulse 2s infinite;
}

.refresh-circle-btn {
  margin: 0 !important;
  padding: 0 !important;
  width: 60rpx !important;
  height: 60rpx !important;
  min-width: 60rpx !important;
  border-radius: 50% !important;
  background: rgba(255, 255, 255, 0.15) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.22) !important;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  transition: all var(--duration-fast) var(--ease-smooth);
  box-sizing: border-box;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}

.refresh-circle-btn::after {
  border: none !important;
}

.refresh-circle-btn:active {
  transform: scale(0.88);
  background: rgba(255, 255, 255, 0.30) !important;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.04);
}

.refresh-icon-spin {
  width: 22rpx;
  height: 22rpx;
  position: relative;
}

.refresh-icon-spin::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  border: 3rpx solid #ffffff;
  border-top-color: transparent;
  border-radius: 50%;
  box-sizing: border-box;
}

.refresh-icon-spin::after {
  content: '';
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid #ffffff;
  border-bottom: 6rpx solid transparent;
  border-top: 6rpx solid transparent;
  transform: rotate(-45deg);
}

.is-refreshing .refresh-icon-spin {
  animation: rotate 1.0s linear infinite;
}

/* 右侧拍立得相框 */
.hero-polaroid-aside {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 180rpx;
}

.polaroid-card {
  background: #ffffff;
  padding: 14rpx 14rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 20rpx 48rpx rgba(21, 46, 82, 0.28);
  transform: rotate(4deg);
  transition: all var(--duration-normal) var(--ease-spring);
}

.polaroid-card:active {
  transform: rotate(0deg) scale(1.08);
  box-shadow: 0 24rpx 56rpx rgba(21, 46, 82, 0.35);
}

.polaroid-photo {
  width: 156rpx;
  height: 156rpx;
  border-radius: 6rpx;
  background: var(--color-bg-page);
}

.polaroid-caption {
  font-size: 16rpx;
  color: var(--color-text-tertiary);
  font-weight: 700;
  text-align: center;
  margin-top: 10rpx;
  letter-spacing: 0.5rpx;
}

/* 统计卡片网格 */
.stat-grid {
  margin: var(--spacing-lg) var(--spacing-2xl) var(--spacing-lg);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-md);
}

.block-title {
  margin: 38rpx var(--spacing-2xl) 12rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.block-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
}
