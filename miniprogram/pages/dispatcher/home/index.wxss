/* 调配首页 */
.hero-note {
  margin-top: 28rpx;
  padding: 14rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.5;
  position: relative;
  z-index: 1;
}

.stat-grid {
  margin: -52rpx 32rpx 28rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.block-title {
  margin: 38rpx 32rpx 12rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #1A2332;
}

.shortcut-grid {
  margin: 24rpx 32rpx 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.shortcut-card {
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(26, 35, 50, 0.06),
              0 12rpx 32rpx rgba(26, 35, 50, 0.04);
  transition: transform 0.2s ease;
}

.shortcut-card:active {
  transform: scale(0.97);
}

.shortcut-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A2332;
}

.shortcut-desc {
  margin-top: 12rpx;
  color: #5A6B82;
  font-size: 24rpx;
  line-height: 1.5;
}
