@import "../../../styles/shared.wxss";

/* 管家详情 */
.butler-hero-card {
  margin: 12rpx var(--spacing-2xl) var(--spacing-lg);
  padding: 56rpx 32rpx;
  border-radius: var(--radius-lg);
  text-align: center;
  color: #ffffff;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 60%, var(--color-primary-darker) 100%);
  box-shadow: 0 8rpx 32rpx rgba(42, 172, 226, 0.25);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 装饰性圆形与呼吸 */
.butler-hero-card::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  animation: decorBreathe 8s ease-in-out infinite;
}

.butler-hero-card::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  animation: decorBreathe 6s ease-in-out infinite 2s;
}

.avatar-glow {
  position: absolute;
  left: 50%;
  top: 56rpx;
  transform: translateX(-50%);
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  filter: blur(8px);
  animation: pulse 2.5s ease-in-out infinite;
  pointer-events: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  font-size: 56rpx;
  line-height: 120rpx;
  font-weight: 800;
  position: relative;
  z-index: 1;
  border: 4rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: var(--shadow-sm);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.butler-name {
  font-size: 38rpx;
  font-weight: 800;
  position: relative;
  z-index: 1;
  margin-bottom: var(--spacing-sm);
}

.row-emoji-icon {
  font-size: 32rpx;
  line-height: 1;
  filter: grayscale(0.1);
  margin-right: var(--spacing-xs);
}

.row-value {
  text-align: right;
  font-weight: 600;
}

/* 接待中列表项 */
.assignment {
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.assignment:last-child {
  border-bottom: 0;
}

.row-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--color-text-primary);
}

.row-sub {
  margin: var(--spacing-xs) 0 var(--spacing-md);
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 500;
}

.tag-row {
  display: flex;
}
