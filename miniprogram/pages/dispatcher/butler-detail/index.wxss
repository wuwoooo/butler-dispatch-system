/* 管家详情 */
.status-line {
  margin: 12rpx 32rpx 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #EDF1F7;
}

.detail-row:last-child {
  border-bottom: 0;
}

.row-label {
  color: #5A6B82;
  font-size: 26rpx;
}

.row-value {
  color: #1A2332;
  font-size: 27rpx;
  font-weight: 600;
}

.assignment {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EDF1F7;
}

.assignment:last-child {
  border-bottom: 0;
}

.row-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1A2332;
}

.row-sub,
.empty-lite {
  margin: 10rpx 0;
  color: #5A6B82;
  font-size: 24rpx;
}
