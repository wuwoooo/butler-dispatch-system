<page-container title="{{butler.name || '管家详情'}}">
  <view class="butler-hero-card anim-fade-in">
    <view class="avatar-glow"></view>
    <view class="avatar">{{avatar}}</view>
    <view class="butler-name">{{butler.name}}</view>
    <status-tag type="butler" value="{{butler.status}}" />
  </view>

  <view class="anim-fade-in anim-stagger-1">
    <section-card title="基础信息">
      <view wx:for="{{rows}}" wx:key="0" wx:for-item="row" class="detail-row">
        <view class="row-label">
          <view class="row-dot-decor"></view>
          <text>{{row[0]}}</text>
        </view>
        <view class="row-value">{{row[1] || '-'}}</view>
      </view>
    </section-card>
  </view>

  <view class="anim-fade-in anim-stagger-2">
    <section-card title="当前接待">
      <view wx:for="{{assignments}}" wx:key="id" class="assignment">
        <view class="row-title">{{item.order.hotel.name}} · {{item.order.guestName}}</view>
        <view class="row-sub">时间：{{item.dateText}}</view>
        <view class="tag-row">
          <status-tag type="assignment" value="{{item.status}}" />
        </view>
      </view>
      <empty-state wx:if="{{assignments.length === 0}}" scene="default" title="暂无活跃接待" description="该管家当前没有正在进行的服务" />
    </section-card>
  </view>
</page-container>
