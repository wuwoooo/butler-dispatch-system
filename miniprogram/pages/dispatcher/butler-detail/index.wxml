<page-container title="{{butler.name || '管家详情'}}" subtitle="档案、状态与当前接待">
  <view class="status-line"><status-tag type="butler" value="{{butler.status}}" /></view>
  <section-card title="基础信息">
    <view wx:for="{{rows}}" wx:key="0" wx:for-item="row" class="detail-row">
      <view class="row-label">{{row[0]}}</view>
      <view class="row-value">{{row[1] || '-'}}</view>
    </view>
  </section-card>
  <section-card title="当前接待">
    <view wx:for="{{assignments}}" wx:key="id" class="assignment">
      <view class="row-title">{{item.order.hotel.name}} · {{item.order.guestName}}</view>
      <view class="row-sub">{{item.dateText}}</view>
      <status-tag type="assignment" value="{{item.status}}" />
    </view>
    <view wx:if="{{assignments.length === 0}}" class="empty-lite">当前没有活跃接待</view>
  </section-card>
</page-container>

