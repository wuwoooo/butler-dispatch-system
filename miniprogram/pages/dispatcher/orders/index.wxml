<page-container title="订单调配">
  <view class="search-bar anim-fade-in">
    <view class="search-input-wrap">
      <view class="search-icon"></view>
      <input class="search-input" placeholder="输入客人姓名搜索" value="{{keyword}}" bindinput="setKeyword" confirm-type="search" bindconfirm="load" />
    </view>
    <button class="search-btn" bindtap="load">确认搜索</button>
  </view>

  <scroll-view class="tab-scroll anim-fade-in" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tab-capsule-group">
      <view wx:for="{{tabs}}" wx:key="key" class="tab-capsule {{active === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="switchTab">{{item.text}}</view>
    </view>
  </scroll-view>

  <block wx:if="{{!loading}}">
    <order-card wx:for="{{items}}" wx:key="id" class="anim-fade-in anim-stagger-{{index % 5 + 1}}" item="{{item}}" bind:tap="openDetail" />
    <empty-state wx:if="{{items.length === 0}}" scene="orders" title="暂无订单" description="当前状态下没有符合的订单任务" buttonText="重新加载" bind:refresh="load" />
  </block>

  <loading-state wx:else mode="skeleton" skeletonRows="3" />

  <app-navbar role="dispatcher" active="orders" />
</page-container>
