@import "../../../styles/shared.wxss";

/* 请假审核额外样式 */
.tab-scroll {
  margin-top: var(--spacing-sm);
}

.leave-card {
  margin-bottom: var(--spacing-lg) !important;
}

.leave-detail-row {
  margin-top: var(--spacing-sm);
}

.detail-label {
  color: var(--color-text-tertiary);
  font-weight: 600;
  width: 140rpx;
}

.detail-value {
  color: var(--color-text-secondary);
  font-weight: 500;
}

.reject-icon {
  margin-right: 4rpx;
}

.actions {
  margin-top: var(--spacing-lg);
  display: flex;
  gap: var(--spacing-xl);
}

.approve,
.reject {
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box;
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-full);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-smooth);
}

.approve::after,
.reject::after {
  border: none !important;
}

.approve {
  background: linear-gradient(135deg, var(--color-success) 0%, var(--color-success-deep) 100%);
  box-shadow: 0 4rpx 14rpx rgba(16, 185, 129, 0.30);
}

.reject {
  background: linear-gradient(135deg, var(--color-danger) 0%, var(--color-danger-deep) 100%);
  box-shadow: 0 4rpx 14rpx rgba(239, 68, 68, 0.30);
}

.approve:active,
.reject:active {
  transform: scale(0.97);
  box-shadow: none;
}
