<page-container title="请假审核" subtitle="处理管家请假申请">
  <scroll-view class="tab-scroll anim-fade-in" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tab-capsule-group">
      <view wx:for="{{tabs}}" wx:key="key" class="tab-capsule {{active === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="switchTab">{{item.text}}</view>
    </view>
  </scroll-view>

  <block wx:if="{{!loading}}">
    <view wx:for="{{items}}" wx:key="id" class="leave-card anim-fade-in anim-stagger-{{index % 5 + 1}}">
      <view class="leave-top">
        <view class="leave-type">{{item.butler.name}} · {{item.typeText}}</view>
        <status-tag type="leave" value="{{item.status}}" />
      </view>
      <view class="leave-detail-row">
        <view class="detail-label">请假时间</view>
        <view class="detail-value">{{item.startText}} 至 {{item.endText}}</view>
      </view>
      <view class="leave-detail-row">
        <view class="detail-label">申请原因</view>
        <view class="detail-value">{{item.reason}}</view>
      </view>
      <view wx:if="{{item.reviewRemark}}" class="leave-reason-block">
        驳回原因：{{item.reviewRemark}}
      </view>
      <view wx:if="{{item.status === 'pending'}}" class="actions">
        <button class="approve" data-id="{{item.id}}" bindtap="approve">通过</button>
        <button class="reject" data-id="{{item.id}}" bindtap="reject">驳回</button>
      </view>
    </view>
    <empty-state wx:if="{{items.length === 0}}" scene="leave" title="暂无请假审批记录" description="当前筛选条件下没有待处理或历史请假申请" />
  </block>

  <loading-state wx:else mode="skeleton" skeletonRows="3" />

  <app-navbar role="dispatcher" active="leave" />
</page-container>
