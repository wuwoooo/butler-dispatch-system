/* 调配个人中心 */
.profile-card {
  margin: 12rpx 32rpx 24rpx;
  padding: 48rpx 32rpx;
  border-radius: 32rpx;
  text-align: center;
  color: #ffffff;
  background: linear-gradient(135deg, #2AACE2 0%, #1B8FD4 60%, #2B5EA7 100%);
  box-shadow: 0 8rpx 32rpx rgba(42, 172, 226, 0.28);
  position: relative;
  overflow: hidden;
}

.profile-card::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.profile-card::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.avatar {
  width: 116rpx;
  height: 116rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  font-size: 52rpx;
  line-height: 116rpx;
  font-weight: 800;
  position: relative;
  z-index: 1;
  border: 4rpx solid rgba(255, 255, 255, 0.30);
}

.name {
  font-size: 38rpx;
  font-weight: 800;
  position: relative;
  z-index: 1;
}

.role {
  margin-top: 10rpx;
  font-size: 25rpx;
  opacity: 0.85;
  position: relative;
  z-index: 1;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  color: #5A6B82;
  font-size: 27rpx;
  border-bottom: 1rpx solid #EDF1F7;
}

.row:last-child {
  border-bottom: 0;
}

.change-password {
  margin: 32rpx 32rpx 0;
  height: 88rpx;
  border-radius: 999rpx;
  color: #1B8FD4;
  background: #EAF6FD;
  font-size: 30rpx;
  font-weight: 800;
  transition: all 0.2s ease;
}

.change-password:active {
  transform: scale(0.97);
  background: #D9EFFB;
}

.logout {
  margin: 24rpx 32rpx 32rpx;
  height: 88rpx;
  border-radius: 999rpx;
  color: #EF4444;
  background: #FEF2F2;
  font-size: 30rpx;
  font-weight: 800;
  transition: all 0.2s ease;
}

.logout:active {
  transform: scale(0.97);
  background: #FEE2E2;
}
