/* 登录页 — 阿鹏哥旅游 */
.login-page {
  min-height: 100vh;
  padding: 0 40rpx;
  background: #EFF3FA;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰性渐变背景 */
.login-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 56vh;
  background: linear-gradient(160deg, #2AACE2 0%, #1B8FD4 40%, #2B5EA7 100%);
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
}

/* 装饰性圆形 */
.login-bg::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.07);
}

.login-bg::after {
  content: '';
  position: absolute;
  bottom: 40rpx;
  left: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

/* 品牌logo区域 */
.brand {
  position: relative;
  z-index: 2;
  text-align: center;
  padding-top: 160rpx;
  margin-bottom: 60rpx;
}

.brand-logo {
  width: 320rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.15));
}

.brand-subtitle {
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* 登录卡片 */
.login-card {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 40rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(26, 35, 50, 0.06),
              0 16rpx 48rpx rgba(26, 35, 50, 0.08);
}

.card-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1A2332;
}

.card-desc {
  margin: 18rpx 0 36rpx;
  color: #5A6B82;
  font-size: 26rpx;
  line-height: 1.65;
}

/* 加载状态 */
.login-loading {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
  color: #2AACE2;
  font-size: 26rpx;
}

.login-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #EAF6FD;
  border-top-color: #2AACE2;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 二级操作 */
.secondary {
  margin-top: 28rpx;
  text-align: center;
  color: #2AACE2;
  font-size: 27rpx;
  font-weight: 600;
  transition: opacity 0.2s;
}

.secondary:active {
  opacity: 0.7;
}

/* 底部版权 */
.footer {
  position: relative;
  z-index: 2;
  margin-top: auto;
  padding: 40rpx 0 calc(40rpx + env(safe-area-inset-bottom));
  color: #94A3B8;
  font-size: 22rpx;
  text-align: center;
  letter-spacing: 1rpx;
}
