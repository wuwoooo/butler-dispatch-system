@import "../../styles/shared.wxss";

/* 登录页 — 沉浸式高级 Splash 屏 */
.login-page {
  min-height: 100vh;
  background: #0F1E36;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  padding: 0 var(--spacing-2xl);
}

/* 渐变发光底色 */
.login-bg-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 32%, #1C5492 0%, #0F1E36 78%);
  z-index: 1;
  pointer-events: none;
}

.brand-container {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 72rpx;
  margin-top: -60rpx;
}

/* 圆形发光品牌艺术徽章 */
.brand-avatar-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 36rpx;
}

.brand-avatar-glow {
  position: absolute;
  inset: -10rpx;
  border-radius: 50%;
  background: rgba(42, 172, 226, 0.28);
  filter: blur(12px);
  animation: pulse 3s infinite;
}

.brand-avatar-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(15, 30, 54, 0.35);
  box-sizing: border-box;
}

.brand-title {
  font-size: 38rpx;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.25);
}

.brand-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 12rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 登录状态区 */
.login-interactive-area {
  position: relative;
  z-index: 2;
  width: 100%;
  min-height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 加载态毛玻璃面板 */
.loader-glass-panel {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
}

.loader-ring-spin {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.35);
  border-top-color: #2AACE2;
  border-radius: 50%;
  animation: rotate 0.8s linear infinite;
  box-sizing: border-box;
}

.loader-text {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

/* 失败/绑定控制卡 */
.control-glass-card {
  width: 100%;
  padding: 44rpx var(--spacing-xl);
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 24rpx 56rpx rgba(15, 30, 54, 0.3);
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
}

.card-tip {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
  font-weight: 600;
}

.action-btn-gap {
  margin-bottom: var(--spacing-md);
}

.bind-secondary-btn {
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary-deep);
  background: var(--color-primary-light);
  border-radius: var(--radius-full);
  border: none;
  transition: all var(--duration-fast) var(--ease-smooth);
}

.bind-secondary-btn::after {
  border: none !important;
}

.bind-secondary-btn:active {
  background: var(--color-primary-lighter);
  transform: scale(0.97);
}

/* 底部版权信息 */
.footer-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 40rpx 0 calc(40rpx + env(safe-area-inset-bottom));
  z-index: 2;
}

.footer-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  font-weight: 700;
  letter-spacing: 6rpx;
  text-indent: 6rpx;
}

.footer-copy {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.22);
  font-weight: 500;
}
