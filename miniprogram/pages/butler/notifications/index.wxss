@import "../../../styles/shared.wxss";

/* 管家通知 */
.notification-header {
  margin: 12rpx var(--spacing-2xl) var(--spacing-md);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.count-badge {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
  background: var(--color-bg-input);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
}

.read-all-btn {
  width: auto !important;
  margin: 0 !important;
  padding: 0 var(--spacing-lg) !important;
  box-sizing: border-box;
  height: 64rpx;
  border-radius: var(--radius-full);
  color: var(--color-primary);
  background: var(--color-primary-light);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 6rpx;
  box-shadow: 0 4rpx 10rpx rgba(42, 172, 226, 0.08);
  transition: all var(--duration-fast) var(--ease-smooth);
}

.read-all-btn::after {
  border: none !important;
}

.read-all-btn:active {
  background: var(--color-primary-lighter);
  transform: scale(0.96);
  box-shadow: none;
}

.read-icon {
  font-size: 22rpx;
}
