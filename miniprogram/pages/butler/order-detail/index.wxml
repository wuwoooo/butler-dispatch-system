<page-container title="{{order.hotel.name || '订单详情'}}" subtitle="订单号：{{order.orderNo}}">
  <view class="status-line">
    <status-tag type="order" value="{{order.status}}" />
    <status-tag wx:if="{{assignment.status}}" type="assignment" value="{{assignment.status}}" />
  </view>

  <section-card wx:for="{{sections}}" wx:key="title" title="{{item.title}}">
    <view wx:for="{{item.rows}}" wx:key="0" wx:for-item="row" class="detail-row">
      <view class="row-label">{{row[0]}}</view>
      <view class="row-value">{{row[1] || '-'}}</view>
    </view>
  </section-card>

  <view wx:if="{{actions.length}}" class="fixed-action">
    <view wx:for="{{actions}}" wx:key="action" class="action-gap">
      <primary-button
        wx:if="{{!item.reject}}"
        text="{{item.text}}"
        tone="{{item.tone}}"
        data-action="{{item.action}}"
        bind:tap="doAction"
      />
      <primary-button
        wx:else
        text="{{item.text}}"
        tone="{{item.tone}}"
        bind:tap="reject"
      />
    </view>
  </view>
</page-container>
