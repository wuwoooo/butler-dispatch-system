@import "../../../styles/shared.wxss";

/* 管家请假记录 */
.apply-btn {
  width: calc(100% - var(--spacing-2xl) * 2) !important;
  margin: 12rpx var(--spacing-2xl) var(--spacing-md) !important;
  padding: 0 !important;
  box-sizing: border-box;
  height: 88rpx;
  border-radius: var(--radius-full);
  color: var(--color-primary);
  background: var(--color-primary-light);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(42, 172, 226, 0.12);
  transition: all var(--duration-fast) var(--ease-smooth);
}

.apply-btn::after,
.cancel-btn::after {
  border: none !important;
}

.apply-btn:active {
  background: var(--color-primary-lighter);
  transform: scale(0.97);
  box-shadow: none;
}

.leave-detail-row {
  margin-top: var(--spacing-sm);
}

.detail-label {
  color: var(--color-text-tertiary);
  font-weight: 600;
  width: 140rpx;
}

.detail-value {
  color: var(--color-text-secondary);
  font-weight: 500;
}

.reject-icon {
  margin-right: 4rpx;
}

.cancel-btn {
  margin-top: var(--spacing-lg) !important;
  width: 100% !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
  padding: 0 !important;
  box-sizing: border-box;
  height: 72rpx;
  border-radius: var(--radius-md);
  color: var(--color-danger);
  background: var(--color-danger-light);
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(239, 68, 68, 0.15);
  transition: all var(--duration-fast);
}

.cancel-btn:active {
  transform: scale(0.98);
  background: #FEE2E2;
}
