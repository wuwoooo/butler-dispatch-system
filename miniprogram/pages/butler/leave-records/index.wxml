<page-container title="请假记录">
  <button class="apply-btn anim-fade-in" bindtap="apply">＋ 新增请假申请</button>

  <view wx:for="{{items}}" wx:key="id" class="leave-card anim-fade-in anim-stagger-{{index % 5 + 1}}">
    <view class="leave-top">
      <view class="leave-type">{{item.typeText}}</view>
      <status-tag type="leave" value="{{item.status}}" />
    </view>
    <view class="leave-detail-row">
      <view class="detail-label">请假时间</view>
      <view class="detail-value">{{item.startText}} 至 {{item.endText}}</view>
    </view>
    <view class="leave-detail-row">
      <view class="detail-label">申请原因</view>
      <view class="detail-value">{{item.reason}}</view>
    </view>
    <view wx:if="{{item.reviewRemark}}" class="leave-reason-block">
      驳回原因：{{item.reviewRemark}}
    </view>
    <button wx:if="{{item.status === 'pending'}}" class="cancel-btn" data-id="{{item.id}}" bindtap="cancel">撤销申请</button>
  </view>

  <empty-state wx:if="{{items.length === 0}}" scene="leave" title="暂无请假记录" description="需要休息或休假时可以提交请假申请" buttonText="去申请请假" bind:refresh="apply" />
  <app-navbar role="butler" active="leave" />
</page-container>
