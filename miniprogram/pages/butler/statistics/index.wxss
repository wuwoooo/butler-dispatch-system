/* 管家数据统计 */
.range-tabs {
  margin: 12rpx 32rpx 24rpx;
  display: flex;
  gap: 0;
  padding: 6rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(26, 35, 50, 0.06);
}

.range-tab {
  flex: 1;
  height: 68rpx;
  border-radius: 20rpx;
  text-align: center;
  line-height: 68rpx;
  background: transparent;
  color: #5A6B82;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.25s ease;
}

.active {
  background: linear-gradient(135deg, #2AACE2 0%, #1B8FD4 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 14rpx rgba(42, 172, 226, 0.30);
}

.stat-grid {
  margin: 0 32rpx 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.mini-row,
.review-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EDF1F7;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.clickable-row {
  position: relative;
  border-radius: 12rpx;
  transition: background 0.2s ease;
}

.clickable-row:active {
  background: #F4F8FC;
}

.mini-row:last-child,
.review-card:last-child {
  border-bottom: 0;
}

.review-card {
  display: block;
}

.row-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2332;
}

.row-sub {
  margin-top: 8rpx;
  color: #5A6B82;
  font-size: 24rpx;
}

.row-status {
  color: #2AACE2;
  font-size: 24rpx;
  font-weight: 600;
}
