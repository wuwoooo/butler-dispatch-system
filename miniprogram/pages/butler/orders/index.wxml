<page-container title="我的订单" subtitle="按接待状态查看任务">
  <scroll-view class="tab-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tab-capsule-group">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-capsule {{active === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="switchTab"
      >{{item.text}}</view>
    </view>
  </scroll-view>

  <block wx:if="{{!loading}}">
    <order-card
      wx:for="{{items}}"
      wx:key="id"
      class="anim-fade-in anim-stagger-{{index % 5 + 1}}"
      item="{{item}}"
      showActions="{{active === 'pending'}}"
      bind:tap="openDetail"
      bind:confirm="confirm"
      bind:reject="reject"
    />
    <empty-state wx:if="{{items.length === 0}}" scene="orders" title="暂无订单" description="当前状态下没有分配的接待任务" buttonText="刷新列表" bind:refresh="load" />
  </block>

  <loading-state wx:else mode="skeleton" skeletonRows="3" />

  <app-navbar role="butler" active="orders" />
</page-container>
