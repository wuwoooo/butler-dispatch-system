<page-container title="请假申请">
  <view class="anim-fade-in anim-stagger-1">
    <section-card title="请假时间">
      <form-cell label="开始日期" required>
        <picker mode="date" bindchange="setStartDate">
          <view class="picker {{startDate ? 'has-value' : 'placeholder'}}">{{startDate || '请选择开始日期'}}</view>
        </picker>
      </form-cell>
      <form-cell label="开始时间">
        <picker mode="time" bindchange="setStartTime">
          <view class="picker {{startTime ? 'has-value' : 'placeholder'}}">{{startTime || '请选择开始时间（默认为 00:00）'}}</view>
        </picker>
      </form-cell>
      <form-cell label="结束日期" required>
        <picker mode="date" bindchange="setEndDate">
          <view class="picker {{endDate ? 'has-value' : 'placeholder'}}">{{endDate || '请选择结束日期'}}</view>
        </picker>
      </form-cell>
      <form-cell label="结束时间">
        <picker mode="time" bindchange="setEndTime">
          <view class="picker {{endTime ? 'has-value' : 'placeholder'}}">{{endTime || '请选择结束时间（默认为 23:59）'}}</view>
        </picker>
      </form-cell>
    </section-card>
  </view>

  <view class="anim-fade-in anim-stagger-2">
    <section-card title="请假信息">
      <form-cell label="请假类型" required>
        <picker range="{{leaveTypes}}" range-key="label" value="{{leaveTypeIndex}}" bindchange="setType">
          <view class="picker {{leaveTypeIndex !== -1 ? 'has-value' : 'placeholder'}}">
            {{leaveTypeIndex !== -1 ? leaveTypes[leaveTypeIndex].label : '请选择请假类型'}}
          </view>
        </picker>
      </form-cell>
      <form-cell label="请假原因" required>
        <view class="textarea-container">
          <textarea class="textarea" placeholder="请详细填写请假原因（不超过 200 字）" maxlength="200" value="{{reason}}" bindinput="setReason" />
          <view class="char-count">{{reason.length}}/200</view>
        </view>
      </form-cell>
    </section-card>
  </view>

  <view class="fixed-action anim-fade-in anim-stagger-3">
    <primary-button text="提交请假申请" loading="{{submitting}}" disabled="{{submitting}}" bind:tap="handleSubmit" />
  </view>
</page-container>
