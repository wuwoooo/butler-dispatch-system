<page-container title="个人中心" subtitle="账号信息与登录状态">
  <view class="profile-card anim-fade-in">
    <!-- 右下角品牌插画融合 -->
    <image class="profile-card-decor" src="/assets/images/profile-hero.png" mode="aspectFill" />
    
    <view class="profile-card-content">
      <view class="avatar-wrap-profile">
        <view class="avatar-glow"></view>
        <view class="avatar">{{avatar}}</view>
      </view>
      <view class="profile-info">
        <view class="name">{{user.name || '-'}}</view>
        <view class="role-tag">管家账号</view>
      </view>
    </view>
  </view>

  <!-- 品质服务承诺卡 -->
  <view class="quality-card anim-fade-in anim-stagger-1">
    <image class="quality-img" src="/assets/images/profile-hero.png" mode="aspectFit" />
    <view class="quality-info">
      <view class="quality-tag">品质承诺</view>
      <view class="quality-title">秉承白族好客之道</view>
      <view class="quality-desc">大理阿鹏哥专属认证管家</view>
      <view class="quality-sub">专业 · 细致 · 安全 · 安心</view>
    </view>
  </view>

  <view class="anim-fade-in anim-stagger-2">
    <section-card title="账号信息">
      <view class="detail-row">
        <view class="row-label">
          <view class="row-dot-decor"></view>
          <text>用户名</text>
        </view>
        <view class="row-value">{{user.username || '-'}}</view>
      </view>
      <view class="detail-row">
        <view class="row-label">
          <view class="row-dot-decor"></view>
          <text>账号角色</text>
        </view>
        <view class="row-value">{{roleText}}</view>
      </view>
      <view class="detail-row">
        <view class="row-label">
          <view class="row-dot-decor"></view>
          <text>管家档案</text>
        </view>
        <view class="row-value">{{user.butlerId ? '已绑定' : '未绑定'}}</view>
      </view>
      <view class="detail-row">
        <view class="row-label">
          <view class="row-dot-decor"></view>
          <text>终端状态</text>
        </view>
        <view class="row-value">小程序端·已授权</view>
      </view>
    </section-card>
  </view>

  <view class="action-buttons anim-fade-in anim-stagger-3">
    <button class="change-password" bindtap="goChangePassword">修改登录密码</button>
    <button class="logout" bindtap="logout">退出当前账号</button>
  </view>

  <view class="app-version anim-fade-in anim-stagger-4">
    <text>阿鹏哥管家调配系统 v1.2.5</text>
    <text class="copyright">© 2026 阿鹏哥旅游. All Rights Reserved.</text>
  </view>

  <app-navbar role="butler" active="profile" />
</page-container>
