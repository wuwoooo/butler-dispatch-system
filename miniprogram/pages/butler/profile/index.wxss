@import "../../../styles/shared.wxss";

/* 管家个人中心 */
.profile-card {
  margin: 12rpx var(--spacing-2xl) var(--spacing-lg);
  padding: 48rpx var(--spacing-xl);
  border-radius: var(--radius-lg);
  color: #ffffff;
  background: linear-gradient(135deg, #2AACE2 0%, #1A3C6B 60%, #152E52 100%);
  box-shadow: 0 12rpx 36rpx rgba(26, 60, 107, 0.25);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  min-height: 240rpx;
  box-sizing: border-box;
}

/* 右下角品牌插图 */
.profile-card-decor {
  position: absolute;
  right: -24rpx;
  bottom: -40rpx;
  width: 290rpx;
  height: 290rpx;
  opacity: 0.92;
  z-index: 1;
  pointer-events: none;
  /* 右下角淡入淡出遮罩 */
  -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%), linear-gradient(to top, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%);
  -webkit-mask-composite: source-in;
  mask-image: linear-gradient(to left, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%), linear-gradient(to top, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 100%);
  mask-composite: intersect;
}

.profile-card-content {
  display: flex;
  align-items: center;
  gap: var(--spacing-lg);
  position: relative;
  z-index: 2;
  width: 100%;
}

.avatar-wrap-profile {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  flex-shrink: 0;
}

.avatar-glow {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  filter: blur(6px);
  animation: pulse 2.5s ease-in-out infinite;
  pointer-events: none;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.20);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  font-size: 46rpx;
  line-height: 100rpx;
  font-weight: 800;
  border: 3rpx solid rgba(255, 255, 255, 0.45);
  box-shadow: var(--shadow-sm);
  text-align: center;
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 36rpx;
  font-weight: 800;
  text-shadow: 0 2rpx 4rpx rgba(21, 46, 82, 0.2);
}

.role-tag {
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.16);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.row-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
}

.row-value {
  color: var(--color-text-primary);
  font-weight: 600;
  text-align: right;
}

/* 按钮区域 */
.action-buttons {
  margin-top: var(--spacing-xl);
  padding: 0 var(--spacing-2xl);
}

.change-password {
  width: 100% !important;
  margin: 0 0 var(--spacing-md) !important;
  padding: 0 !important;
  box-sizing: border-box;
  height: 88rpx;
  border-radius: var(--radius-full);
  color: var(--color-primary-deep);
  background: var(--color-primary-light);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-smooth);
  box-shadow: 0 4rpx 12rpx rgba(42, 172, 226, 0.1);
}

.change-password::after,
.logout::after {
  border: none !important;
}

.change-password:active {
  transform: scale(0.98);
  background: var(--color-primary-lighter);
  box-shadow: none;
}

.logout {
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box;
  height: 88rpx;
  border-radius: var(--radius-full);
  color: var(--color-danger);
  background: var(--color-danger-light);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-smooth);
  border: 1rpx solid rgba(239, 68, 68, 0.12);
}

.logout:active {
  transform: scale(0.98);
  background: #FEE2E2;
}

/* 版本与脚注 */
.app-version {
  margin-top: 60rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-weight: 500;
}

.copyright {
  font-size: 18rpx;
  opacity: 0.75;
}
